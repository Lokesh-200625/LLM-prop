# =============================================================================
# .env.example — copy to .env.local for local development
#
# DO NOT commit real secrets. This file is safe to commit.
# =============================================================================

# -----------------------------------------------------------------------------
# DATABASE (PostgreSQL)
# -----------------------------------------------------------------------------
# Local dev: use the docker-compose postgres service.
# Production: use Neon / Supabase / Railway / any managed Postgres.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/llmprop

# -----------------------------------------------------------------------------
# NEXT-AUTH
# -----------------------------------------------------------------------------
# Generate a strong secret: openssl rand -base64 32
NEXTAUTH_SECRET=replace_with_a_strong_random_secret

# Set to your public URL.
# Local dev: http://localhost:3000
# Production (Vercel): https://your-app.vercel.app
NEXTAUTH_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# OAUTH — Google
# Create credentials at https://console.cloud.google.com/
# Authorised redirect URI: <NEXTAUTH_URL>/api/auth/callback/google
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# OAUTH — GitHub
# Create an OAuth App at https://github.com/settings/developers
# Callback URL: <NEXTAUTH_URL>/api/auth/callback/github
# -----------------------------------------------------------------------------
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# PYTHON WORKER
# Local dev: worker runs on http://localhost:8000 (default)
# Production: set to your Render service URL, e.g. https://llm-prop-worker.onrender.com
# -----------------------------------------------------------------------------
WORKER_API_URL=http://localhost:8000

# How long (ms) the Next.js backend waits for the worker before returning 504.
# Increase to 60000+ for Render free-tier cold starts.
PREDICTION_TIMEOUT_MS=30000

# =============================================================================
# Variables below are only needed in the worker (worker/.env or Render dashboard)
# They are NOT read by the Next.js app.
# =============================================================================

# Comma-separated origins that the worker allows via CORS.
# Must include your Vercel frontend URL in production.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# HuggingFace repo that contains bandgapquantized.onnx + tokenizer/.
# Leave blank to use local files at worker/models/band_gap/.
BANDGAP_HF_REPO_ID=

# Branch / tag / commit SHA to pin. Defaults to "main".
BANDGAP_HF_REVISION=main

# ONNX model filename inside the repo. Defaults to "bandgapquantized.onnx".
BANDGAP_HF_MODEL_FILENAME=bandgapquantized.onnx

# Tokenizer subdirectory inside the repo. Defaults to "tokenizer".
BANDGAP_HF_TOKENIZER_DIRNAME=tokenizer

# HuggingFace API token — only required if the HF repo is private.
HF_TOKEN=

# Where the worker stores downloaded models.
# Recommended on Render: mount a Disk at /data/models and set this.
MODEL_CACHE_DIR=

# Inference device: "cpu" (default) or "cuda" (requires CUDA onnxruntime).
MODEL_DEVICE=cpu

# Worker server settings.
WORKER_HOST=0.0.0.0
WORKER_PORT=8000
LOG_LEVEL=INFO
MAX_TEXT_LENGTH=5000
